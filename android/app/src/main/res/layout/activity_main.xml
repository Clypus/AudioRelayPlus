<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="monospace"
        android:text="@string/status_ready"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/gainLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/gain_label" />

    <SeekBar
        android:id="@+id/gainBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="300" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <CheckBox
            android:id="@+id/nsBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/noise_suppress" />

        <CheckBox
            android:id="@+id/aecBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/phone_aec" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/usbBox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/usb_mode" />

    <Button
        android:id="@+id/scanBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/scan" />

    <ListView
        android:id="@+id/serverList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/padLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/soundpad"
        android:textStyle="bold"
        android:visibility="gone" />

    <GridView
        android:id="@+id/padGrid"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:horizontalSpacing="6dp"
        android:numColumns="3"
        android:verticalSpacing="6dp"
        android:visibility="gone" />

    <EditText
        android:id="@+id/manualIp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/manual_ip_hint"
        android:imeOptions="actionDone"
        android:inputType="text"
        android:maxLines="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/connectBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="@string/connect" />

        <Button
            android:id="@+id/stopBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/stop" />

        <ToggleButton
            android:id="@+id/muteBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textOff="@string/unmute"
            android:textOn="@string/mute" />
    </LinearLayout>
</LinearLayout>
